# Database
# Tuned pool: connection_limit=20 (per instance), pool_timeout=15s, connect_timeout=10s.
# Rationale: backend is I/O-bound, Postgres default max_connections=100, leaves headroom
# for admin sessions, migrations, and secondary services (face-service scripts).
DATABASE_URL="postgresql://gymuser:gympass@localhost:5432/gym_saas?schema=public&connection_limit=20&pool_timeout=15&connect_timeout=10"

# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Auth — access token (JWT in Authorization header)
JWT_SECRET="change-me-in-production-at-least-32-chars-long"
JWT_EXPIRES_IN="8h"

# Auth — refresh token (httpOnly cookie)
REFRESH_SECRET="change-me-too-and-keep-it-different-from-jwt-secret"
REFRESH_EXPIRES_IN="30d"
COOKIE_SECRET="change-me-at-least-32-chars-long-cookie-secret"
COOKIE_SECURE="false"
# COOKIE_DOMAIN=example.com

# CORS — frontend origin(s), comma-separated
CORS_ORIGIN="http://localhost:5173"

# Photo uploads — directory (relative to backend cwd) where member photos are stored
PHOTOS_DIR="./data/photos"

# Face recognition service
FACE_SERVICE_URL="http://localhost:8001"
FACE_MATCH_THRESHOLD="0.6"

# Backup system
BACKUPS_DIR="./data/backups"
BACKUP_CRON="0 3 * * *"                    # nightly 03:00 local time
BACKUP_RETENTION_DAILY="30"                # keep last 30 daily backups
BACKUP_RETENTION_MONTHLY="12"              # keep last 12 monthly backups
BACKUP_MODE="prisma"                       # "prisma" (JSON snapshots) or "pgdump" (requires pg_dump in PATH)
BACKUP_AUTO_ON_PAYMENT="true"              # trigger incremental JSON snapshot after every financial txn
PG_DUMP_PATH="pg_dump"                     # absolute path to pg_dump when BACKUP_MODE=pgdump

# Backup restore protection — a random secret the client must send to confirm restores
BACKUP_RESTORE_TOKEN="change-me-at-least-16-chars-long-restore-token"

# SMS provider (attendance alerts)
SMS_PROVIDER="console"                     # "console" | "twilio" | "vonage" | "http"
SMS_FROM="+213000000000"
SMS_DAILY_PER_MEMBER_CAP="5"               # max SMS per member per calendar day
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
VONAGE_API_KEY=""
VONAGE_API_SECRET=""
SMS_HTTP_URL=""
SMS_HTTP_TOKEN=""
