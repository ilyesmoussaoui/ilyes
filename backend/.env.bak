# Database
DATABASE_URL="postgresql://gymuser:gympass@localhost:5432/gym_saas?schema=public"

# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Auth — access token
JWT_SECRET="change-me-in-production-at-least-32-chars-long"
JWT_EXPIRES_IN="8h"

# Auth — refresh token
REFRESH_SECRET="change-me-too-and-keep-it-different-from-jwt-secret"
REFRESH_EXPIRES_IN="30d"
COOKIE_SECURE="false"

# CORS
CORS_ORIGIN="http://localhost:5173"
